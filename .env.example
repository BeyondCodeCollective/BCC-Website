# Beyond Code Collective — Environment Variables
# Copy this file to .env.local and fill in your values

# Anthropic — Powers the AI career guide chat in the quiz
ANTHROPIC_API_KEY=your-anthropic-api-key

# Resend — Email delivery and audience management
RESEND_API_KEY=your-resend-api-key
RESEND_AUDIENCE_ID=your-resend-audience-id
RESEND_FROM_EMAIL=BCC Career Quiz <quiz@wearebcc.org>
